{
  "name": "@nathanclaire/edge-telemetry-sdk",
  "version": "3.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A lightweight React Native SDK for collecting mobile app telemetry and exporting it to custom backends in JSON format. Built for flexible and developer-friendly observability.",
  "private": false,
  "main": "dist/index.web.js",
  "module": "dist/index.web.js",
  "types": "dist/index.web.d.ts",
  "react-native": "dist/index.native.js",
  "exports": {
    ".": {
      "types": {
        "web": "./dist/index.web.d.ts",
        "react-native": "./dist/index.native.d.ts",
        "default": "./dist/index.web.d.ts"
      },
      "import": {
        "web": "./dist/index.web.js",
        "react-native": "./dist/index.native.js",
        "default": "./dist/index.web.js"
      },
      "require": {
        "web": "./dist/index.web.cjs",
        "react-native": "./dist/index.native.cjs",
        "default": "./dist/index.web.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.21.0",
    "react": ">=17",
    "react-dom": ">=17",
    "react-native-device-info": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-device-info": {
      "optional": true
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "react-native",
    "telemetry",
    "monitoring",
    "sdk",
    "observability",
    "analytics",
    "crash-reporting",
    "performance",
    "ios",
    "android",
    "user-profiles",
    "react",
    "web"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/react-navigation": "^3.0.8",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": ">=1.21.0",
    "@react-native-community/netinfo": "^11.4.1",
    "react-native-device-info": "^12.0.0",
    "react-native-get-random-values": "^1.11.0",
    "uuid": "^13.0.0"
  }
}
